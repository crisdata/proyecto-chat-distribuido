# Base de datos MariaDB
MYSQL_ROOT_PASSWORD=cambia_esta_contraseña
MYSQL_DATABASE=chat_db
MYSQL_USER=chat_user
MYSQL_PASSWORD=cambia_esta_contraseña

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Ollama
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_MODEL=llama3.2:3b

# API
API_HOST=0.0.0.0
API_PORT=8000

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Worker — URL interna de la API dentro de Docker
API_INTERNA_URL=http://api:8000

# Seguridad — Bloque 2
# JWT_SECRET firma los tokens de sesión de los usuarios.
# Debe ser una cadena aleatoria larga, distinta en cada despliegue.
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=cambia_esta_clave_por_una_aleatoria_larga

# WORKER_SECRET autentica al worker cuando llama a /interno/notificar.
# Solo el worker y la API deben conocerla. Generar igual que JWT_SECRET.
WORKER_SECRET=cambia_esta_clave_por_una_aleatoria_larga